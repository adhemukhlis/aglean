{
  "name": "aglean",
  "type": "module",
  "version": "1.0.1",
  "description": "Agnostic, native-first, and zero-dependency utility functions.",
  "author": "adhemukhlis",
  "license": "ISC",
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "format": "prettier --config .prettierrc --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
    "fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "semver:patch": "pnpm version patch",
    "semver:minor": "pnpm version minor",
    "semver:major": "pnpm version major",
    "semver:publish": "pnpm publish --access public"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.6.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adhemukhlis/leanx.git"
  },
  "bugs": {
    "url": "https://github.com/adhemukhlis/leanx/issues"
  },
  "homepage": "https://github.com/adhemukhlis/leanx#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./array": {
      "default": "./dist/array.mjs",
      "import": "./dist/array.mjs",
      "types": "./dist/array.d.mts"
    },
    "./common": {
      "default": "./dist/common.mjs",
      "import": "./dist/common.mjs",
      "types": "./dist/common.d.mts"
    },
    "./crypto": {
      "default": "./dist/crypto.mjs",
      "import": "./dist/crypto.mjs",
      "types": "./dist/crypto.d.mts"
    },
    "./function": {
      "default": "./dist/function.mjs",
      "import": "./dist/function.mjs",
      "types": "./dist/function.d.mts"
    },
    "./map": {
      "default": "./dist/map.mjs",
      "import": "./dist/map.mjs",
      "types": "./dist/map.d.mts"
    },
    "./number": {
      "default": "./dist/number.mjs",
      "import": "./dist/number.mjs",
      "types": "./dist/number.d.mts"
    },
    "./object": {
      "default": "./dist/object.mjs",
      "import": "./dist/object.mjs",
      "types": "./dist/object.d.mts"
    },
    "./regex": {
      "default": "./dist/regex.mjs",
      "import": "./dist/regex.mjs",
      "types": "./dist/regex.d.mts"
    },
    "./string": {
      "default": "./dist/string.mjs",
      "import": "./dist/string.mjs",
      "types": "./dist/string.d.mts"
    },
    "./validator": {
      "default": "./dist/validator.mjs",
      "import": "./dist/validator.mjs",
      "types": "./dist/validator.d.mts"
    }
  }
}
